# 배포 시 호스팅(Vercel) 환경변수에 넣는 값. 개발은 로컬 .env 사용.
# 개발 중 비워두면 vite proxy가 localhost:8000으로 넘김. 배포 시 Render 백엔드 주소:
# VITE_API_BASE=https://jusikdo-ai-backend.onrender.com
VITE_API_BASE=

# Supabase (로그인 + 내 데이터 저장). Supabase 프로젝트 Settings에서 복사.
# anon(publishable) 키는 브라우저 공개 안전. Secret 키는 절대 넣지 말 것.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxx
